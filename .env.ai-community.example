# ───────────────────────────────────────────────────────────────────────────
#  Internal deploy: AI Community under https://ai4news.rnd.huawei.com/ai-community
#  Two login methods: Email & Password (always) + Huawei W3 SSO (this file turns it on).
#  Copy to `.env` on the internal box and fill the 4 blanks marked « FILL ».
#  Deep guide + troubleshooting: docs/huawei-sso-deploy.md
# ───────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASS@127.0.0.1:5432/skills_community   # « FILL »

# ─── Auth.js ──────────────────────────────────────────────
AUTH_SECRET=                                                          # « FILL »  openssl rand -base64 32
# Auth.js base URL = the FULL public path to the auth API: <origin>/<subpath>/api/auth.
# It must end in /api/auth (NOT just /ai-community): @auth/core matches the incoming
# request path against this, and builds the SSO callback as <AUTH_URL>/callback/huawei.
# So this exact value ⇒ callback https://ai4news.rnd.huawei.com/ai-community/api/auth/callback/huawei.
# (The app also pins basePath from NEXT_BASE_PATH in code, so this can't silently drift.)
AUTH_URL=https://ai4news.rnd.huawei.com/ai-community/api/auth
# Subpath this app is served under (MUST be present at build time — Next bakes it in;
# also drives the client/server Auth.js basePath). No trailing slash.
NEXT_BASE_PATH=/ai-community

# ─── Storage ──────────────────────────────────────────────
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./storage

# ─── Huawei UniPortal SSO ─────────────────────────────────
# D2: reuse ai4news's existing registration. Same host ⇒ the callback
#   https://ai4news.rnd.huawei.com/ai-community/api/auth/callback/huawei
# is a valid subdirectory of ai4news's registered 应用域名, so no new 备案 is needed.
ENABLE_SSO=true
SSO_CLIENT_ID=                                                        # « FILL »  = ai4news's client_id
SSO_CLIENT_SECRET=                                                    # « FILL »  = ai4news's client_secret
# Informational only (Auth.js derives the real callback from AUTH_URL). This is the
# URL Huawei must accept — confirm it sits under ai4news's 应用域名 in the IDaaS console.
SSO_REDIRECT_URI=https://ai4news.rnd.huawei.com/ai-community/api/auth/callback/huawei
SSO_AUTHORIZE_URL=https://uniportal.huawei.com/saaslogin1/oauth2/authorize
SSO_ACCESS_TOKEN_URL=https://uniportal.huawei.com/saaslogin1/oauth2/accesstoken
SSO_USERINFO_URL=https://uniportal.huawei.com/saaslogin1/oauth2/userinfo
SSO_SCOPE=base.profile
# uniportal's internal cert chain often won't validate from inside — keep false.
SSO_VERIFY_SSL=false

# Direct egress: this box reaches uniportal.huawei.com itself. If token/userinfo
# calls time out, flip USE_PROXY=true (proxyca.huawei.com:8080).
USE_PROXY=false
HUAWEI_PROXY_HOST=proxyca.huawei.com
HUAWEI_PROXY_PORT=8080

# ─── Initial Admin (auto-created on first boot if no admin exists) ────────────
INITIAL_ADMIN_EMAIL=admin@huawei.com
INITIAL_ADMIN_PASSWORD=                                               # « FILL »  change before first boot

# ─── Email links / public base URL ────────────────────────
APP_URL=https://ai4news.rnd.huawei.com/ai-community

# ─── LLM provider (Chat / Try-It / Comparison) ───────────────────────────────
# Switch provider purely by env, then rebuild + restart. Two presets:
#
# (A) INTERNAL model — OpenAI-compatible (vLLM/SGLang), NO API key. Use this on the intranet:
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=http://10.212.16.36:8001/v1          # must include /v1 (the app POSTs /v1/chat/completions)
LLM_MODEL=zai-org/GLM-5.1-FP8
LLM_API_KEY=                                       # internal model is keyless — leave empty
#
# (B) EXTERNAL Anthropic — to switch, comment out (A)'s 4 lines and uncomment these:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# # LLM_MODEL optional for Anthropic (defaults to claude-haiku-4-5)
#
# After changing: NEXT_BASE_PATH=/ai-community pnpm build && sudo systemctl restart ai-community
