// Skills Community — Prisma schema
// 14 core tables covering users, auth, audit, skills, social, CLI tokens.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ─────────────────────────────────────────────────────────

enum AuthMethod {
  password
  huawei_sso
  both
}

model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  handle             String     @unique
  displayName        String
  passwordHash       String?
  huaweiW3Id         String?    @unique
  authMethod         AuthMethod @default(password)
  avatarUrl          String?
  bio                String?
  isAdmin            Boolean    @default(false)
  isActive           Boolean    @default(true)
  canPublishSkills   Boolean    @default(true)
  canPublishInternal Boolean    @default(false)
  canRemix           Boolean    @default(true)
  canUseCli          Boolean    @default(true)
  dailyDownloadLimit Int?
  dailyPublishLimit  Int?
  lastLoginAt        DateTime?
  lastLoginIp        String?
  lastSeenAt         DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  skills          Skill[]              @relation("AuthoredSkills")
  reviews         Review[]
  favorites       Favorite[]
  likes           Like[]
  subscriptions   Subscription[]
  loginEvents     LoginEvent[]
  pageVisits      PageVisit[]
  adminActions    AdminLog[]           @relation("AdminActor")
  cliTokens       CliToken[]
  downloads       Download[]
  accessRequests  SkillAccessRequest[] @relation("AccessRequester")
  accessDecisions SkillAccessRequest[] @relation("AccessDecider")

  // ── Video board back-relations (virtual; no SQL columns on User) ──
  uploadedVideos    Video[]            @relation("UploadedVideos")
  guestVideos       Video[]            @relation("GuestVideos")
  videoViews        VideoView[]
  videoLikes        VideoLike[]
  videoFavorites    VideoFavorite[]
  videoComments     VideoComment[]
  videoCommentLikes VideoCommentLike[]

  @@index([handle])
  @@index([email])
  @@index([isAdmin])
  @@index([lastLoginAt])
}

enum LoginMethod {
  password
  huawei_sso
}

model LoginEvent {
  id            String      @id @default(cuid())
  userId        String?
  method        LoginMethod
  ip            String?
  userAgent     String?
  success       Boolean
  failureReason String?
  createdAt     DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([success])
}

model PageVisit {
  id        String   @id @default(cuid())
  userId    String
  path      String
  pageName  String?
  referrer  String?
  userAgent String?
  ip        String?
  visitedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, visitedAt])
  @@index([path, visitedAt])
}

model AdminLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  targetType  String?
  targetId    String?
  details     Json?
  ip          String?
  createdAt   DateTime @default(now())

  adminUser User @relation("AdminActor", fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}

// ─── Taxonomy ────────────────────────────────────────────────────────────

model Category {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  parentId    String?
  sortOrder   Int     @default(0)

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  skills   Skill[]

  @@index([parentId])
}

model Tag {
  id         String @id @default(cuid())
  slug       String @unique
  name       String
  usageCount Int    @default(0)

  skills SkillTag[]
}

model SkillTag {
  skillId String
  tagId   String

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([skillId, tagId])
  @@index([tagId])
}

// ─── Skills ──────────────────────────────────────────────────────────────

enum SourceType {
  internal
  user_uploaded
  external_curated
}

enum SkillFormat {
  bundle
  structured
}

enum SkillStatus {
  draft
  published
  archived
}

enum SkillVisibility {
  public // discoverable + downloadable by any logged-in user (current behavior)
  restricted // discoverable, but file contents + download gated behind an approved access request
  private // only the owner (and admins, in the admin panel) can see / edit / download / test
}

enum AccessRequestStatus {
  pending
  approved
  rejected
  revoked
}

model Skill {
  id                String          @id @default(cuid())
  slug              String          @unique
  name              String
  summary           String
  descriptionMd     String          @default("")
  authorId          String
  categoryId        String?
  sourceType        SourceType      @default(user_uploaded)
  skillFormat       SkillFormat     @default(bundle)
  status            SkillStatus     @default(draft)
  visibility        SkillVisibility @default(public)
  currentVersionId  String?         @unique
  structuredPayload Json?
  externalSourceUrl String?
  license           String?         @default("MIT")
  homepageUrl       String?
  repoUrl           String?
  downloadCount     Int             @default(0)
  favoriteCount     Int             @default(0)
  likeCount         Int             @default(0)
  reviewCount       Int             @default(0)
  subscriberCount   Int             @default(0)
  remixCount        Int             @default(0)
  avgRating         Float           @default(0)
  trendingScore     Float           @default(0)
  tokenCostEstimate Int             @default(0)
  triggerHitRate    Float?
  forkedFromId      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  author         User          @relation("AuthoredSkills", fields: [authorId], references: [id], onDelete: Cascade)
  category       Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  currentVersion SkillVersion? @relation("CurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  forkedFrom     Skill?        @relation("Forks", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forks          Skill[]       @relation("Forks")

  versions       SkillVersion[]       @relation("AllVersions")
  tags           SkillTag[]
  downloads      Download[]
  reviews        Review[]
  favorites      Favorite[]
  likes          Like[]
  subscriptions  Subscription[]
  accessRequests SkillAccessRequest[]
  comparison     SkillComparison?

  @@index([status, sourceType])
  @@index([visibility, status])
  @@index([categoryId])
  @@index([authorId])
  @@index([trendingScore])
  @@index([createdAt])
  @@index([forkedFromId])
}

// Per-skill access requests for `restricted` skills. One row per (skill, user):
// re-applying after a rejection/revocation mutates the existing row back to `pending`.
// Access is granted iff status === approved (ongoing, revocable).
model SkillAccessRequest {
  id           String              @id @default(cuid())
  skillId      String
  userId       String // applicant
  status       AccessRequestStatus @default(pending)
  message      String? // applicant note (申请理由)
  decidedById  String? // author or admin who approved / rejected / revoked
  decidedAt    DateTime?
  decisionNote String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  skill     Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user      User  @relation("AccessRequester", fields: [userId], references: [id], onDelete: Cascade)
  decidedBy User? @relation("AccessDecider", fields: [decidedById], references: [id], onDelete: SetNull)

  @@unique([skillId, userId])
  @@index([skillId, status])
  @@index([userId, status])
}

// Author-generated, editable "install vs not" comparison shown on a skill's
// Comparison tab. One row per skill. The `example` JSON holds a real dual-run
// ({ taskPrompt, withOutput, withoutOutput }); `bodyMd` is the structured
// analysis report a visitor reads. Generated/edited in the author-side workshop.
model SkillComparison {
  id                    String   @id @default(cuid())
  skillId               String   @unique
  status                String   @default("draft") // draft | published
  bodyMd                String?
  example               Json?
  guidancePrompt        String?
  model                 String?
  generatedForVersionId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
}

enum VersionStatus {
  draft
  published
  yanked
}

model SkillVersion {
  id             String        @id @default(cuid())
  skillId        String
  version        String
  major          Int
  minor          Int
  patch          Int
  changelogMd    String        @default("")
  storageUrl     String?
  contentInline  String?
  manifestJson   Json?
  fileCount      Int           @default(0)
  totalBytes     Int           @default(0)
  checksumSha256 String?
  status         VersionStatus @default(draft)
  tokenCost      Int           @default(0)
  downloadCount  Int           @default(0)
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())

  skill           Skill          @relation("AllVersions", fields: [skillId], references: [id], onDelete: Cascade)
  currentForSkill Skill?         @relation("CurrentVersion")
  downloads       Download[]
  reviews         Review[]
  subscriptions   Subscription[]
  files           SkillFile[]

  @@unique([skillId, version])
  @@index([skillId, major, minor, patch])
  @@index([status])
}

model SkillFile {
  id        String  @id @default(cuid())
  versionId String
  path      String
  size      Int
  isText    Boolean @default(true)
  content   String?
  truncated Boolean @default(false)

  version SkillVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, path])
  @@index([versionId])
}

// ─── Social ──────────────────────────────────────────────────────────────

enum DownloadClient {
  web
  cli
}

model Download {
  id         String         @id @default(cuid())
  skillId    String
  versionId  String?
  userId     String?
  client     DownloadClient @default(web)
  clientMeta Json?
  ipHash     String?
  via        String? // 'download' | 'raw' | 'install' | 'update' | 'try'
  userAgent  String?
  grantId    String? // SkillAccessRequest.id when this was a gated (restricted) download
  createdAt  DateTime       @default(now())

  skill   Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)
  version SkillVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  user    User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([skillId, createdAt])
  @@index([skillId, userId])
  @@index([versionId, createdAt])
  @@index([userId])
  @@index([createdAt])
}

model Favorite {
  userId    String
  skillId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@index([skillId])
}

model Like {
  userId    String
  skillId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@index([skillId])
}

model Subscription {
  userId             String
  skillId            String
  installedVersionId String?
  createdAt          DateTime  @default(now())
  notifiedAt         DateTime?

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill            Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)
  installedVersion SkillVersion? @relation(fields: [installedVersionId], references: [id], onDelete: SetNull)

  @@id([userId, skillId])
  @@index([skillId])
}

model Review {
  id          String   @id @default(cuid())
  skillId     String
  versionId   String?
  authorId    String
  rating      Int
  bodyMd      String
  authorReply String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  skill   Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)
  version SkillVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  author  User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([skillId, authorId])
  @@index([skillId, createdAt])
}

// ─── CLI ─────────────────────────────────────────────────────────────────

model CliToken {
  id          String    @id @default(cuid())
  userId      String
  name        String
  tokenHash   String
  tokenPrefix String
  scopes      String[]  @default([])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenPrefix])
}

model DeviceCode {
  deviceCode String    @id
  userCode   String    @unique
  userId     String?
  expiresAt  DateTime
  approvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userCode])
  @@index([expiresAt])
}

// ─── Video board ───────────────────────────────────────────────────────────
// A self-contained YouTube/TikTok-style board. Every Video* model FKs ONLY to
// User or Video* — never Skill. Self-hosted videos live in object storage; the
// DB holds metadata + a URL. AI summary is cached on Video; chat is stateless.

enum VideoStatus {
  draft
  processing
  published
  unlisted
  archived
}

enum VideoVisibility {
  public
  unlisted
  private
}

enum VideoSourceType {
  admin_curated
  user_uploaded
  external_embed
}

enum VideoCommentStatus {
  visible
  hidden
  deleted
}

model VideoCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  coverKey    String?
  parentId    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   VideoCategory?  @relation("VideoCategoryHierarchy", fields: [parentId], references: [id])
  children VideoCategory[] @relation("VideoCategoryHierarchy")
  videos   Video[]

  @@index([parentId])
  @@index([sortOrder])
}

model VideoTag {
  id         String            @id @default(cuid())
  slug       String            @unique
  name       String
  usageCount Int               @default(0)
  videos     VideoTagOnVideo[]

  @@index([usageCount])
}

model VideoTagOnVideo {
  videoId   String
  tagId     String
  createdAt DateTime @default(now())

  video Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  tag   VideoTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([videoId, tagId])
  @@index([tagId])
}

model Video {
  id            String @id @default(cuid())
  slug          String @unique
  title         String
  summary       String @default("") // feed caption (≠ AI summary)
  descriptionMd String @default("")

  // Media (self-hosted, object storage; browser direct upload)
  videoKey    String?
  videoUrl    String?
  posterKey   String?
  posterUrl   String?
  previewKey  String? // optional dedicated hover-preview clip; falls back to first seconds of source
  previewUrl  String?
  mimeType    String  @default("video/mp4")
  sizeBytes   Int     @default(0)
  width       Int?
  height      Int?
  durationSec Int     @default(0)
  externalUrl String? // external_embed only (phase-2)

  // Status / classification
  status      VideoStatus     @default(draft)
  visibility  VideoVisibility @default(public)
  sourceType  VideoSourceType @default(admin_curated)
  uploaderId  String
  categoryId  String?
  language    String?
  featured    Boolean         @default(false)
  featuredAt  DateTime?
  publishedAt DateTime?

  // Interviewee ("AI 极客访谈"), all optional
  intervieweeName      String?
  intervieweeTitle     String?
  intervieweeOrg       String?
  intervieweeBio       String?
  intervieweeAvatarKey String?
  guestUserId          String?

  // Denormalized counters
  viewCount     Int   @default(0)
  likeCount     Int   @default(0)
  commentCount  Int   @default(0)
  favoriteCount Int   @default(0)
  trendingScore Float @default(0)

  // AI (cached summary columns; chat is stateless)
  transcriptText      String?
  aiSummaryMd         String?
  aiSummaryModel      String?
  aiSummaryAt         DateTime?
  aiSummarySourceHash String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  uploader  User              @relation("UploadedVideos", fields: [uploaderId], references: [id], onDelete: Cascade)
  guestUser User?             @relation("GuestVideos", fields: [guestUserId], references: [id], onDelete: SetNull)
  category  VideoCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags      VideoTagOnVideo[]
  comments  VideoComment[]
  likes     VideoLike[]
  favorites VideoFavorite[]
  views     VideoView[]

  @@index([status, visibility])
  @@index([publishedAt])
  @@index([categoryId])
  @@index([uploaderId])
  @@index([featured, publishedAt])
  @@index([trendingScore])
  @@index([createdAt])
}

model VideoComment {
  id         String             @id @default(cuid())
  videoId    String
  authorId   String
  parentId   String?
  bodyMd     String
  status     VideoCommentStatus @default(visible)
  likeCount  Int                @default(0)
  replyCount Int                @default(0)
  pinned     Boolean            @default(false)
  editedAt   DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  video   Video              @relation(fields: [videoId], references: [id], onDelete: Cascade)
  author  User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  VideoComment?      @relation("VideoCommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies VideoComment[]     @relation("VideoCommentThread")
  likes   VideoCommentLike[]

  @@index([videoId, createdAt])
  @@index([parentId])
}

model VideoCommentLike {
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment VideoComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId])
}

model VideoLike {
  userId    String
  videoId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([userId, videoId])
  @@index([videoId])
}

model VideoFavorite {
  userId    String
  videoId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([userId, videoId])
  @@index([videoId])
}

model VideoView {
  id          String   @id @default(cuid())
  videoId     String
  userId      String?
  sessionHash String // sha256( (userId | ipHash) + videoId + UTC-day ) — day-bucket dedupe
  createdAt   DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([videoId, sessionHash])
  @@index([videoId])
}
