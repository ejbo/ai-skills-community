# systemd unit for the AI Community (skills-community) Next.js app under /ai-community.
#
# Install:
#   sudo cp deploy/ai-community.service /etc/systemd/system/ai-community.service
#   # then edit the two BOX-SPECIFIC lines below: ExecStart node path (run `which node`)
#   sudo systemctl daemon-reload && sudo systemctl enable --now ai-community
# Logs:    journalctl -u ai-community -f
# Status:  systemctl status ai-community
#
# Requires a prior build:  NEXT_BASE_PATH=/ai-community pnpm build
[Unit]
Description=AI Community (skills-community) Next.js app under /ai-community
After=network.target postgresql.service

[Service]
Type=simple
User=ai4news
Group=ai4news
WorkingDirectory=/opt/cari_projects/ai-skills-community
# Next.js auto-loads .env from WorkingDirectory → DATABASE_URL, AUTH_URL, AUTH_SECRET,
# SSO_* all come from there. NEXT_BASE_PATH is set here too so basePath is correct at
# `next start` as well as build time.
Environment=NODE_ENV=production
Environment=NEXT_BASE_PATH=/ai-community
# If the box needs a CA bundle to trust uniportal's cert, uncomment (preferred over
# NODE_TLS_REJECT_UNAUTHORIZED=0):
# Environment=NODE_EXTRA_CA_CERTS=/etc/ssl/certs/huawei-ca-bundle.pem
#
# Call node directly (robust; avoids pnpm's `--` arg forwarding). The path below is this
# box's nvm node — re-check with `which node` and update it if you upgrade node (the nvm path
# contains the version). Keep the FULL command: <node> node_modules/next/dist/bin/next start …
# (a bare `<node> start` fails — `start` isn't a file). If native libs fail, add:
#   Environment=PATH=/home/ai4news/.nvm/versions/node/v24.17.0/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/home/ai4news/.nvm/versions/node/v24.17.0/bin/node node_modules/next/dist/bin/next start -p 3100 -H 127.0.0.1
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
