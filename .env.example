# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skills_community

# ─── Auth.js ──────────────────────────────────────────────
AUTH_SECRET=replace-me-with-a-random-32-byte-string
# Auth.js base URL. For a SUBPATH deploy it must be the full path to the auth API,
# INCLUDING /api/auth — e.g. https://ai4news.rnd.huawei.com/community/api/auth
# (NOT just /community). @auth/core matches the request path against this and builds
# the SSO callback as <AUTH_URL>/callback/huawei. At root, http://localhost:3000 is fine.
# The app also pins basePath from NEXT_BASE_PATH in code, so the two can't drift.
AUTH_URL=http://localhost:3000
# Subpath this app is served under (build-time). Empty = root/local. e.g. /community
NEXT_BASE_PATH=

# ─── Storage ──────────────────────────────────────────────
# Use 'local' for development, 'blob' for Vercel Blob in prod
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./storage
BLOB_READ_WRITE_TOKEN=

# ─── Huawei UniPortal SSO (optional) ──────────────────────
# Set ENABLE_SSO=true to expose the W3 login card. When false, the block below is
# unused and the site runs fully on email/password auth.
# Full deploy guide (registration, nginx, redirect_uri rule): docs/huawei-sso-deploy.md
# D2 reuse: set CLIENT_ID/SECRET to an existing same-host registration's (e.g. ai4news)
# — the callback below is a valid subdirectory of that registered 应用域名.
ENABLE_SSO=false
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
# Informational only (Auth.js derives the real callback from AUTH_URL). This is the URL
# you register with Huawei: <AUTH_URL>/api/auth/callback/huawei
SSO_REDIRECT_URI=http://localhost:3000/api/auth/callback/huawei
SSO_AUTHORIZE_URL=https://uniportal.huawei.com/saaslogin1/oauth2/authorize
SSO_ACCESS_TOKEN_URL=https://uniportal.huawei.com/saaslogin1/oauth2/accesstoken
SSO_USERINFO_URL=https://uniportal.huawei.com/saaslogin1/oauth2/userinfo
SSO_SCOPE=base.profile
SSO_VERIFY_SSL=false

# Corporate proxy (only when running inside Huawei intranet)
USE_PROXY=false
HUAWEI_PROXY_HOST=proxyca.huawei.com
HUAWEI_PROXY_PORT=8080

# ─── Initial Admin ────────────────────────────────────────
# On first startup, if no admin exists, this account is auto-created.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=changeme

# ─── Anthropic API (for Try It feature) ───────────────────
ANTHROPIC_API_KEY=

# ─── Seed sources ─────────────────────────────────────────
ANTHROPIC_SKILLS_REPO=https://github.com/anthropics/skills

# ─── Email (optional) ─────────────────────────────────────
# Notifications for skill download-access requests/decisions.
# When SMTP_HOST/SMTP_FROM are unset, emails are silently skipped (in-app
# notifications still work). APP_URL is the public base URL used in email links.
APP_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Skills Community <no-reply@example.com>"
SMTP_SECURE=false
